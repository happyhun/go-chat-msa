                    "custom": {
                        "lineInterpolation": "smooth",
                        "lineWidth": 2,
                        "fillOpacity": 15,
                        "showPoints": "never"
                    }
                },
                "overrides": [
                    {
                        "matcher": {
                            "id": "byName",
                            "options": "Total"
                        },
                        "properties": [
                            {
                                "id": "custom.lineStyle",
                                "value": {
                                    "fill": "dash",
                                    "dash": [
                                        6,
                                        4
                                    ]
                                }
                            },
                            {
                                "id": "custom.fillOpacity",
                                "value": 0
                            },
                            {
                                "id": "color",
                                "value": {
                                    "mode": "fixed",
                                    "fixedColor": "white"
                                }
                            }
                        ]
                    }
