            },
            "targets": [
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "sum by(service) (container_memory_rss{service=~\"$service\"})",
                    "legendFormat": "{{ service }}",
                    "refId": "A"
                },
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "sum(container_memory_rss{service=~\"$service\"})",
                    "legendFormat": "Total",
                    "refId": "B"
