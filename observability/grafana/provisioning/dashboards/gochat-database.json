                            "options": {
                                "from": 0,
                                "to": 0,
                                "result": {
                                    "text": "NOT RUN"
                                }
                            }
                        },
                        {
                            "type": "range",
                            "options": {
                                "from": 1,
                                "to": 1000,
                                "result": {
                                    "text": "OK"
                                }
                            }
                        }
                    ]
                }
            },
            "targets": [
                {
                    "expr": "increase(gochat_retention_purged_total{status=\"ok\"}[1d]) or vector(0)",
