        {
            "collapsed": false,
            "id": 10,
            "title": "System",
            "type": "row",
            "gridPos": {
                "x": 0,
                "y": 9,
                "w": 24,
                "h": 1
            }
        },
        {
            "id": 11,
            "title": "Build Info",
            "type": "table",
            "gridPos": {
                "x": 0,
                "y": 10,
                "w": 18,
                "h": 5
            },
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "fieldConfig": {
                "defaults": {},
                "overrides": [
                    {
                        "matcher": {
                            "id": "byName",
                            "options": "Value"
                        },
                        "properties": [
                            {
                                "id": "custom.hidden",
                                "value": true
                            }
                        ]
                    },
                    {
                        "matcher": {
                            "id": "byName",
                            "options": "Time"
                        },
                        "properties": [
                            {
                                "id": "custom.hidden",
                                "value": true
                            }
                        ]
                    },
                    {
                        "matcher": {
                            "id": "byName",
                            "options": "vcs_modified"
                        },
                        "properties": [
                            {
                                "id": "custom.cellOptions",
                                "value": {
                                    "mode": "basic",
                                    "type": "color-text"
                                }
                            },
                            {
                                "id": "mappings",
                                "value": [
                                    {
                                        "options": {
                                            "false": {
                                                "color": "green",
                                                "index": 0,
                                                "text": "false"
                                            },
                                            "true": {
                                                "color": "yellow",
                                                "index": 1,
                                                "text": "true"
                                            }
                                        },
                                        "type": "value"
                                    }
                                ]
                            }
                        ]
                    }
                ]
            },
            "options": {},
            "targets": [
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "gochat_build_info",
                    "instant": true,
                    "format": "table",
                    "refId": "A"
                }
            ],
            "transformations": [
                {
                    "id": "organize",
                    "options": {
                        "includeByName": {
                            "service": true,
                            "goversion": true,
                            "vcs_revision": true,
                            "vcs_time": true,
                            "vcs_modified": true
                        },
                        "indexByName": {
                            "service": 0,
                            "goversion": 1,
                            "vcs_revision": 2,
                            "vcs_time": 3,
                            "vcs_modified": 4
                        }
                    }
                }
            ]
        },
        {
            "id": 12,
            "title": "Panics",
            "type": "stat",
            "gridPos": {
                "x": 18,
                "y": 10,
                "w": 6,
                "h": 5
            },
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "short",
                    "decimals": 0,
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "green",
                                "value": null
                            },
                            {
                                "color": "red",
                                "value": 1
                            }
                        ]
                    }
                },
                "overrides": []
            },
            "options": {
                "colorMode": "background",
                "graphMode": "none",
                "justifyMode": "center",
                "orientation": "auto",
                "textMode": "auto",
                "reduceOptions": {
                    "calcs": [
                        "lastNotNull"
                    ]
                }
            },
            "targets": [
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "sum(increase(gochat_panic_recovered_total[$__range]))",
                    "refId": "A"
                }
            ]
        }
    ],
    "refresh": "30s",
    "schemaVersion": 39,
    "tags": [
        "gochat",
        "infra"
    ],
    "templating": {
        "list": [
            {
                "allValue": ".*",
                "current": {
                    "selected": true,
                    "text": [
                        "All"
                    ],
                    "value": [
                        "$__all"
                    ]
                },
                "datasource": {
                    "type": "prometheus",
                    "uid": "prometheus"
                },
                "definition": "label_values(container_cpu_usage_seconds_total, service)",
                "includeAll": true,
                "label": "Service",
                "multi": true,
                "name": "service",
                "query": {
                    "qryType": 1,
                    "query": "label_values(container_cpu_usage_seconds_total, service)"
                },
                "refresh": 2,
                "sort": 1,
                "type": "query"
            }
        ]
    },
    "time": {
        "from": "now-1h",
        "to": "now"
    },
    "timezone": "Asia/Seoul",
    "title": "INFRA",
    "uid": "gochat-infra",
    "version": 1
}