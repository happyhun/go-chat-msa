        {
            "id": 6,
            "title": "Scheduler Latency",
            "type": "timeseries",
            "gridPos": {"x": 0, "y": 9, "w": 12, "h": 8},
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "fieldConfig": {
                "defaults": {
                    "unit": "s",
                    "color": {"mode": "palette-classic"},
                    "custom": {
                        "lineInterpolation": "smooth",
                        "lineWidth": 2,
                        "fillOpacity": 10,
                        "showPoints": "never"
                    }
                },
                "overrides": [
                    {
                        "matcher": {"id": "byRegexp", "options": "^P50 .*"},
                        "properties": [
                            {"id": "custom.lineStyle", "value": {"fill": "dash", "dash": [6, 4]}},
                            {"id": "custom.lineWidth", "value": 1}
                        ]
                    }
                ]
            },
            "options": {
                "tooltip": {"mode": "multi", "sort": "desc"},
                "legend": {
                    "displayMode": "table",
                    "placement": "bottom",
                    "calcs": ["lastNotNull", "max"]
                }
            },
            "targets": [
                {
                    "datasource": {"type": "prometheus", "uid": "prometheus"},
                    "expr": "histogram_quantile(0.50, sum by(service, le) (rate(go_sched_latencies_seconds_bucket{service=~\"$service\"}[$__rate_interval])))",
                    "legendFormat": "P50 {{ service }}",
                    "refId": "A"
                },
                {
                    "datasource": {"type": "prometheus", "uid": "prometheus"},
                    "expr": "histogram_quantile(0.99, sum by(service, le) (rate(go_sched_latencies_seconds_bucket{service=~\"$service\"}[$__rate_interval])))",
                    "legendFormat": "P99 {{ service }}",
                    "refId": "B"
                }
            ]
        },
